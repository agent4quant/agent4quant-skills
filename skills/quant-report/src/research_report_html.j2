<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title }}</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f3f0e8;
        --paper: #fffdf8;
        --ink: #1b1b18;
        --muted: #5e5a52;
        --line: #d9d0bf;
        --accent: #8b5e34;
        --accent-soft: rgba(139, 94, 52, 0.08);
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        background:
          radial-gradient(circle at top left, rgba(139, 94, 52, 0.12), transparent 32%),
          linear-gradient(180deg, #f8f4eb, #f0ebe1);
        color: var(--ink);
        font-family: Georgia, "Songti SC", "Noto Serif SC", serif;
      }
      .page {
        max-width: 1120px;
        margin: 0 auto;
        padding: 40px 20px 60px;
      }
      .hero,
      .section {
        position: relative;
        overflow: hidden;
        background: var(--paper);
        border: 1px solid rgba(139, 94, 52, 0.15);
        border-radius: 28px;
        box-shadow: 0 18px 60px rgba(47, 37, 24, 0.08);
        padding: 28px;
        margin-bottom: 20px;
      }
      .eyebrow,
      .muted {
        color: var(--muted);
      }
      .hero h1,
      .section h2 {
        margin: 0 0 12px;
      }
      .grid {
        display: grid;
        gap: 14px;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      }
      .metric {
        padding: 16px;
        border-radius: 18px;
        background: var(--accent-soft);
        border: 1px solid rgba(139, 94, 52, 0.12);
      }
      table {
        width: 100%;
        border-collapse: collapse;
      }
      th,
      td {
        text-align: left;
        padding: 10px 0;
        border-bottom: 1px solid var(--line);
        vertical-align: top;
      }
      .watermark {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) rotate(-24deg);
        font-size: 72px;
        color: rgba(139, 94, 52, 0.08);
        pointer-events: none;
        white-space: nowrap;
        font-weight: 700;
      }
      @media (max-width: 680px) {
        .hero,
        .section {
          border-radius: 20px;
          padding: 20px;
        }
        .watermark {
          font-size: 42px;
        }
      }
    </style>
  </head>
  <body>
    <main class="page">
      {% set benchmark = result.get('benchmark') %}
      {% set period = result.get('period', {}) %}
      {% set metadata = result.get('metadata', {}) %}
      {% set metrics = result.get('metrics', {}) %}
      {% set cost_model = result.get('cost_model', {}) %}
      {% set strategy_params = result.get('strategy_params', {}) %}
      {% set trades = result.get('trades', []) %}
      <section class="hero">
        {% if watermark %}<div class="watermark">{{ watermark }}</div>{% endif %}
        <p class="eyebrow">Agent4Quant Research Report</p>
        <h1>{{ title }}</h1>
        <p class="muted">标的 {{ result.symbol }} / 策略 {{ result.strategy }} / Benchmark {{ benchmark.symbol if benchmark else "-" }}</p>
        <p class="muted">周期 {{ period.start }} 至 {{ period.end }} / {{ period.interval }}</p>
        <p>{{ metadata.disclaimer or "免责声明：仅供研究与学习使用，不构成投资建议。" }}</p>
      </section>

      <section class="section">
        <h2>核心指标</h2>
        <div class="grid">
          {% for key, value in metrics.items() %}
          <article class="metric">
            <div class="muted">{{ key }}</div>
            <strong>{{ value }}</strong>
          </article>
          {% endfor %}
          {% if not metrics %}
          <article class="metric">
            <div class="muted">metrics</div>
            <strong>当前输入未提供核心指标</strong>
          </article>
          {% endif %}
        </div>
      </section>

      <section class="section">
        <h2>风险与交易摘要</h2>
        <table>
          <tbody>
            <tr><th>最大回撤</th><td>{{ metrics.max_drawdown or "-" }}</td></tr>
            <tr><th>波动率</th><td>{{ metrics.volatility or "-" }}</td></tr>
            <tr><th>夏普比率</th><td>{{ metrics.sharpe or "-" }}</td></tr>
            <tr><th>交易次数</th><td>{{ metrics.trade_count or "-" }}</td></tr>
            <tr><th>胜率</th><td>{{ metrics.win_rate or "-" }}</td></tr>
            <tr><th>总成本</th><td>{{ metrics.total_cost or "-" }}</td></tr>
            <tr><th>超额收益</th><td>{{ metrics.excess_total_return or "-" }}</td></tr>
          </tbody>
        </table>
      </section>

      <section class="section">
        <h2>成本模型与参数</h2>
        <table>
          <thead>
            <tr>
              <th>字段</th>
              <th>值</th>
            </tr>
          </thead>
          <tbody>
            {% for key, value in cost_model.items() %}
            <tr><td>{{ key }}</td><td>{{ value }}</td></tr>
            {% endfor %}
            {% for key, value in strategy_params.items() %}
            <tr><td>{{ key }}</td><td>{{ value }}</td></tr>
            {% endfor %}
            {% if not cost_model and not strategy_params %}
            <tr><td colspan="2">当前输入未提供成本模型或策略参数</td></tr>
            {% endif %}
          </tbody>
        </table>
      </section>

      <section class="section">
        <h2>最近交易</h2>
        <table>
          <thead>
            <tr>
              <th>入场</th>
              <th>出场</th>
              <th>毛收益</th>
              <th>净收益</th>
              <th>状态</th>
            </tr>
          </thead>
          <tbody>
            {% for trade in trades[:8] %}
            <tr>
              <td>{{ trade.entry_date }} / {{ trade.entry_price }}</td>
              <td>{{ trade.exit_date }} / {{ trade.exit_price }}</td>
              <td>{{ trade.gross_return }}</td>
              <td>{{ trade.net_return }}</td>
              <td>{{ trade.status }}</td>
            </tr>
            {% endfor %}
            {% if not trades %}
            <tr><td colspan="5">无完整交易记录</td></tr>
            {% endif %}
          </tbody>
        </table>
      </section>
    </main>
  </body>
</html>
