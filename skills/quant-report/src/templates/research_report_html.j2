<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>{{ title }}</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; max-width: 900px; margin: 0 auto; padding: 20px; }
        h1, h2 { color: #333; border-bottom: 2px solid #2196F3; padding-bottom: 10px; }
        table { width: 100%; border-collapse: collapse; margin: 20px 0; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #ddd; }
        th { background: #f5f5f5; }
        .metric { font-weight: bold; color: #2196F3; }
        .positive { color: #4CAF50; }
        .negative { color: #F44336; }
        .watermark { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%) rotate(-45deg); font-size: 80px; opacity: 0.1; color: #999; pointer-events: none; z-index: -1; }
        .disclaimer { margin-top: 40px; padding: 15px; background: #fff3cd; border-radius: 5px; font-size: 12px; }
    </style>
</head>
<body>
    {% if watermark %}
    <div class="watermark">{{ watermark }}</div>
    {% endif %}

    <h1>{{ title }}</h1>

    <h2>Summary</h2>
    <table>
        {% for key, value in result.metrics.items() %}
        <tr>
            <td>{{ key }}</td>
            <td class="metric">{{ "%.4f"|format(value) if value is number else value }}</td>
        </tr>
        {% endfor %}
    </table>

    {% if result.strategy_params %}
    <h2>Strategy Parameters</h2>
    <table>
        {% for key, value in result.strategy_params.items() %}
        <tr><td>{{ key }}</td><td>{{ value }}</td></tr>
        {% endfor %}
    </table>
    {% endif %}

    {% if result.cost_model %}
    <h2>Cost Model</h2>
    <table>
        {% for key, value in result.cost_model.items() %}
        <tr><td>{{ key }}</td><td>{{ value }}</td></tr>
        {% endfor %}
    </table>
    {% endif %}

    {% if result.trades %}
    <h2>Recent Trades</h2>
    <table>
        <tr>
            <th>Entry Date</th>
            <th>Exit Date</th>
            <th>Entry Price</th>
            <th>Exit Price</th>
            <th>Return</th>
        </tr>
        {% for trade in result.trades[:20] %}
        <tr>
            <td>{{ trade.entry_date }}</td>
            <td>{{ trade.exit_date }}</td>
            <td>{{ "%.4f"|format(trade.entry_price) }}</td>
            <td>{{ "%.4f"|format(trade.exit_price) }}</td>
            <td class="{{ 'positive' if trade.net_return > 0 else 'negative' }}">{{ "%.2f%%"|format(trade.net_return * 100) }}</td>
        </tr>
        {% endfor %}
    </table>
    {% endif %}

    <div class="disclaimer">{{ result.disclaimer or 'Generated by Agent4Quant. For research purposes only.' }}</div>
</body>
</html>
