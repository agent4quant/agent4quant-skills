<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ result.symbol }} 参数扫描报告</title>
    <script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>
    <style>
      body { margin: 0; padding: 32px; font-family: "Helvetica Neue", "PingFang SC", sans-serif; background: #f7f7f2; color: #111827; }
      .wrap { max-width: 1120px; margin: 0 auto; }
      .card { background: #fffef9; border: 1px solid #e7e0cf; border-radius: 24px; padding: 24px; margin-bottom: 18px; box-shadow: 0 18px 40px rgba(17,24,39,0.06); }
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; }
      .metric { padding: 16px; border-radius: 16px; background: linear-gradient(135deg, #f7efe2, #fcfaf4); }
      table { width: 100%; border-collapse: collapse; }
      th, td { text-align: left; padding: 10px 12px; border-bottom: 1px solid #ebe5d8; }
      .small { color: #6b7280; font-size: 14px; }
      .chart { height: 380px; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <section class="card">
        <p class="small">Agent4Quant / Sweep Report</p>
        <h1>{{ result.symbol }} - {{ result.strategy }}</h1>
        <p class="small">Ranking Metric: {{ result.ranking_metric }} / Benchmark: {{ result.benchmark.symbol }}</p>
        {% if result.applied_filters %}
        <p class="small">Filters: {{ result.applied_filters|join(', ') }}</p>
        {% endif %}
        <p class="small">Adjust: {{ result.data_config.adjust }} / Market: {{ result.data_config.market or 'default' }}</p>
        <p>{{ result.metadata.disclaimer }}</p>
      </section>
      <section class="card">
        <h2>摘要</h2>
        <div class="grid">
          <div class="metric"><div class="small">Total Experiments</div><strong>{{ result.total_experiments }}</strong></div>
          <div class="metric"><div class="small">Filtered Out</div><strong>{{ result.filtered_out_experiments }}</strong></div>
          <div class="metric"><div class="small">Returned</div><strong>{{ result.returned_experiments }}</strong></div>
          <div class="metric"><div class="small">Best {{ result.ranking_metric }}</div><strong>{{ result.best_metric_value }}</strong></div>
        </div>
      </section>
      <section class="card">
        <h2>参数扫描图</h2>
        <div id="sweep-chart" class="chart"></div>
      </section>
      <section class="card">
        <h2>最佳参数</h2>
        <table>
          <tbody>
            {% for key, value in result.best_params.items() %}
            <tr><th>{{ key }}</th><td>{{ value }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </section>
      <section class="card">
        <h2>实验排名</h2>
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>参数</th>
              <th>{{ result.ranking_metric }}</th>
              <th>total_return</th>
              <th>benchmark_total_return</th>
              <th>excess_total_return</th>
              <th>max_drawdown</th>
            </tr>
          </thead>
          <tbody>
            {% for item in result.experiments %}
            <tr>
              <td>{{ loop.index }}</td>
              <td>{{ item.strategy_params }}</td>
              <td>{{ item[result.ranking_metric] }}</td>
              <td>{{ item.total_return }}</td>
              <td>{{ item.benchmark_total_return }}</td>
              <td>{{ item.excess_total_return }}</td>
              <td>{{ item.max_drawdown }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </section>
    </div>
    <script>
      const sweepRows = {{ result.experiments | tojson }};
      const rankingMetric = {{ result.ranking_metric | tojson }};
      Plotly.newPlot(
        "sweep-chart",
        [
          {
            x: sweepRows.map((row) => JSON.stringify(row.strategy_params)),
            y: sweepRows.map((row) => row[rankingMetric]),
            type: "bar",
            name: rankingMetric,
            marker: { color: "#b45309" }
          },
          {
            x: sweepRows.map((row) => JSON.stringify(row.strategy_params)),
            y: sweepRows.map((row) => row.total_return),
            type: "scatter",
            mode: "lines+markers",
            name: "total_return",
            line: { color: "#1d4ed8", width: 2 }
          }
        ],
        {
          margin: { t: 20, r: 16, b: 72, l: 48 },
          paper_bgcolor: "#fffef9",
          plot_bgcolor: "#fffef9",
          legend: { orientation: "h" }
        },
        { responsive: true }
      );
    </script>
  </body>
</html>
