<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ result.symbol }} 多策略对比报告</title>
    <script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>
    <style>
      body { margin: 0; padding: 32px; font-family: "Helvetica Neue", "PingFang SC", sans-serif; background: #eef3f0; color: #0f172a; }
      .wrap { max-width: 1120px; margin: 0 auto; }
      .card { background: #ffffff; border-radius: 24px; padding: 24px; margin-bottom: 18px; box-shadow: 0 18px 42px rgba(15,23,42,0.08); }
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; }
      .metric { padding: 16px; border-radius: 16px; background: linear-gradient(135deg, #e8f5ee, #f8fbfa); }
      table { width: 100%; border-collapse: collapse; }
      th, td { text-align: left; padding: 10px 12px; border-bottom: 1px solid #dde6e0; }
      .small { color: #64748b; font-size: 14px; }
      .chart { height: 380px; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <section class="card">
        <p class="small">Agent4Quant / Strategy Compare Report</p>
        <h1>{{ result.symbol }} 多策略对比</h1>
        <p class="small">Ranking Metric: {{ result.ranking_metric }} / Benchmark: {{ result.benchmark.symbol }}</p>
        {% if result.applied_filters %}
        <p class="small">Filters: {{ result.applied_filters|join(', ') }}</p>
        {% endif %}
        <p class="small">Adjust: {{ result.data_config.adjust }} / Market: {{ result.data_config.market or 'default' }}</p>
        <p>{{ result.metadata.disclaimer }}</p>
      </section>
      <section class="card">
        <h2>摘要</h2>
        <div class="grid">
          <div class="metric"><div class="small">Total Strategies</div><strong>{{ result.total_experiments }}</strong></div>
          <div class="metric"><div class="small">Filtered Out</div><strong>{{ result.filtered_out_experiments }}</strong></div>
          <div class="metric"><div class="small">Returned</div><strong>{{ result.returned_experiments }}</strong></div>
          <div class="metric"><div class="small">Best Strategy</div><strong>{{ result.best_strategy }}</strong></div>
          <div class="metric"><div class="small">Best {{ result.ranking_metric }}</div><strong>{{ result.best_metric_value }}</strong></div>
        </div>
      </section>
      <section class="card">
        <h2>收益与风险分布</h2>
        <div id="compare-chart" class="chart"></div>
      </section>
      <section class="card">
        <h2>策略排名</h2>
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>策略</th>
              <th>参数</th>
              <th>{{ result.ranking_metric }}</th>
              <th>total_return</th>
              <th>benchmark_total_return</th>
              <th>excess_total_return</th>
              <th>max_drawdown</th>
            </tr>
          </thead>
          <tbody>
            {% for item in result.experiments %}
            <tr>
              <td>{{ loop.index }}</td>
              <td>{{ item.strategy }}</td>
              <td>{{ item.strategy_params }}</td>
              <td>{{ item[result.ranking_metric] }}</td>
              <td>{{ item.total_return }}</td>
              <td>{{ item.benchmark_total_return }}</td>
              <td>{{ item.excess_total_return }}</td>
              <td>{{ item.max_drawdown }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </section>
    </div>
    <script>
      const compareRows = {{ result.experiments | tojson }};
      Plotly.newPlot(
        "compare-chart",
        [
          {
            x: compareRows.map((row) => row.strategy),
            y: compareRows.map((row) => row.total_return),
            type: "bar",
            name: "total_return",
            marker: { color: "#15803d" }
          },
          {
            x: compareRows.map((row) => row.strategy),
            y: compareRows.map((row) => row.max_drawdown),
            type: "scatter",
            mode: "lines+markers",
            name: "max_drawdown",
            yaxis: "y2",
            line: { color: "#b91c1c", width: 2 }
          }
        ],
        {
          margin: { t: 20, r: 48, b: 48, l: 48 },
          paper_bgcolor: "#ffffff",
          plot_bgcolor: "#ffffff",
          yaxis: { title: "total_return" },
          yaxis2: { title: "max_drawdown", overlaying: "y", side: "right" },
          legend: { orientation: "h" }
        },
        { responsive: true }
      );
    </script>
  </body>
</html>
