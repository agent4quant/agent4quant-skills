<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ result.symbol }} 回测报告</title>
    <script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>
    <style>
      body {
        margin: 0;
        padding: 32px;
        font-family: "Helvetica Neue", "PingFang SC", sans-serif;
        background: #f5f7fb;
        color: #0f172a;
      }
      .wrap {
        max-width: 1080px;
        margin: 0 auto;
      }
      .hero,
      .card {
        background: #ffffff;
        border-radius: 20px;
        padding: 24px;
        box-shadow: 0 20px 60px rgba(15, 23, 42, 0.08);
        margin-bottom: 20px;
      }
      .metrics {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 16px;
      }
      .metric {
        padding: 16px;
        border-radius: 16px;
        background: linear-gradient(135deg, #eff6ff, #f8fafc);
      }
      table {
        width: 100%;
        border-collapse: collapse;
      }
      th,
      td {
        padding: 10px 12px;
        border-bottom: 1px solid #e2e8f0;
        text-align: left;
      }
      .chart {
        height: 380px;
      }
      .small {
        font-size: 14px;
        color: #475569;
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <section class="hero">
        <p class="small">Agent4Quant / Quant Backtest Report</p>
        <h1>{{ result.symbol }} - {{ result.strategy }}</h1>
        <p>{{ result.metadata.disclaimer }}</p>
        <p class="small">
          周期：{{ result.period.start }} 至 {{ result.period.end }} / {{ result.period.interval }}
        </p>
        <p class="small">Benchmark: {{ result.benchmark.symbol }}</p>
        <p class="small">Adjust: {{ result.data_config.adjust }} / Market: {{ result.data_config.market or 'default' }}</p>
      </section>

      <section class="card">
        <h2>核心指标</h2>
        <div class="metrics">
          {% for key, value in result.metrics.items() %}
          <div class="metric">
            <div class="small">{{ key }}</div>
            <strong>{{ value }}</strong>
          </div>
          {% endfor %}
        </div>
      </section>

      <section class="card">
        <h2>净值曲线</h2>
        <div id="equity-chart" class="chart"></div>
      </section>

      <section class="card">
        <h2>回撤与成本</h2>
        <div id="cost-chart" class="chart"></div>
      </section>

      <section class="card">
        <h2>基准对比</h2>
        <table>
          <thead>
            <tr>
              <th>指标</th>
              <th>值</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>benchmark_total_return</td>
              <td>{{ result.metrics.benchmark_total_return }}</td>
            </tr>
            <tr>
              <td>benchmark_annualized_return</td>
              <td>{{ result.metrics.benchmark_annualized_return }}</td>
            </tr>
            <tr>
              <td>excess_total_return</td>
              <td>{{ result.metrics.excess_total_return }}</td>
            </tr>
          </tbody>
        </table>
      </section>

      <section class="card">
        <h2>策略参数</h2>
        <table>
          <thead>
            <tr>
              <th>参数</th>
              <th>取值</th>
            </tr>
          </thead>
          <tbody>
            {% for key, value in result.strategy_params.items() %}
            <tr>
              <td>{{ key }}</td>
              <td>{{ value }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </section>

      <section class="card">
        <h2>成本模型</h2>
        <table>
          <thead>
            <tr>
              <th>参数</th>
              <th>取值</th>
            </tr>
          </thead>
          <tbody>
            {% for key, value in result.cost_model.items() %}
            <tr>
              <td>{{ key }}</td>
              <td>{{ value }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </section>

      <section class="card">
        <h2>交易明细</h2>
        <table>
          <thead>
            <tr>
              <th>入场</th>
              <th>出场</th>
              <th>毛收益</th>
              <th>净收益</th>
              <th>持有条数</th>
              <th>状态</th>
            </tr>
          </thead>
          <tbody>
            {% for trade in result.trades[:10] %}
            <tr>
              <td>{{ trade.entry_date }} / {{ trade.entry_price }}</td>
              <td>{{ trade.exit_date }} / {{ trade.exit_price }}</td>
              <td>{{ trade.gross_return }}</td>
              <td>{{ trade.net_return }}</td>
              <td>{{ trade.holding_bars }}</td>
              <td>{{ trade.status }}</td>
            </tr>
            {% endfor %}
            {% if not result.trades %}
            <tr>
              <td colspan="6">无完整交易记录</td>
            </tr>
            {% endif %}
          </tbody>
        </table>
      </section>
    </div>
    <script>
      const equityCurve = {{ result.equity_curve | tojson }};
      const benchmarkCurve = {{ result.benchmark_curve | tojson }};
      Plotly.newPlot(
        "equity-chart",
        [
          {
            x: equityCurve.map((row) => row.date),
            y: equityCurve.map((row) => row.equity),
            type: "scatter",
            mode: "lines",
            name: "strategy",
            line: { color: "#0f766e", width: 3 }
          },
          {
            x: equityCurve.map((row) => row.date),
            y: equityCurve.map((row) => row.gross_equity),
            type: "scatter",
            mode: "lines",
            name: "gross",
            line: { color: "#1d4ed8", width: 2, dash: "dot" }
          },
          {
            x: benchmarkCurve.map((row) => row.date),
            y: benchmarkCurve.map((row) => row.benchmark_equity),
            type: "scatter",
            mode: "lines",
            name: "benchmark",
            line: { color: "#f59e0b", width: 2 }
          }
        ],
        {
          margin: { t: 20, r: 16, b: 48, l: 48 },
          paper_bgcolor: "#ffffff",
          plot_bgcolor: "#ffffff",
          legend: { orientation: "h" }
        },
        { responsive: true }
      );

      Plotly.newPlot(
        "cost-chart",
        [
          {
            x: equityCurve.map((row) => row.date),
            y: equityCurve.map((row) => row.drawdown),
            type: "scatter",
            mode: "lines",
            name: "drawdown",
            line: { color: "#b91c1c", width: 2 }
          },
          {
            x: equityCurve.map((row) => row.date),
            y: equityCurve.map((row) => row.cost_return),
            type: "bar",
            name: "cost_return",
            marker: { color: "#7c3aed", opacity: 0.35 }
          }
        ],
        {
          margin: { t: 20, r: 16, b: 48, l: 48 },
          paper_bgcolor: "#ffffff",
          plot_bgcolor: "#ffffff",
          legend: { orientation: "h" }
        },
        { responsive: true }
      );
    </script>
  </body>
</html>
