<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ result.symbol }} 因子分析</title>
    <style>
      body { margin: 0; padding: 32px; font-family: "Helvetica Neue", "PingFang SC", sans-serif; background: #f7f5ef; color: #111827; }
      .wrap { max-width: 1080px; margin: 0 auto; }
      .card { background: #fffef9; border: 1px solid #ece4d4; border-radius: 24px; padding: 24px; margin-bottom: 18px; box-shadow: 0 18px 40px rgba(17,24,39,0.06); }
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; }
      .metric { padding: 16px; border-radius: 16px; background: linear-gradient(135deg, #f7efe2, #fcfaf4); }
      table { width: 100%; border-collapse: collapse; }
      th, td { text-align: left; padding: 10px 12px; border-bottom: 1px solid #ebe5d8; }
      .small { color: #6b7280; font-size: 14px; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <section class="card">
        <p class="small">Agent4Quant / Quant Alpha Report</p>
        <h1>{{ result.symbol }} 因子分析</h1>
        <p class="small">Best Factor: {{ result.best_factor }} / Horizon: {{ result.config.horizon }} / IC Window: {{ result.config.ic_window }}</p>
        <p>{{ result.metadata.disclaimer }}</p>
      </section>
      <section class="card">
        <h2>配置</h2>
        <div class="grid">
          <div class="metric"><div class="small">Factors</div><strong>{{ result.config.factors|join(', ') }}</strong></div>
          <div class="metric"><div class="small">Indicators</div><strong>{{ result.config.indicators|join(', ') }}</strong></div>
          <div class="metric"><div class="small">Horizon</div><strong>{{ result.config.horizon }}</strong></div>
          <div class="metric"><div class="small">IC Window</div><strong>{{ result.config.ic_window }}</strong></div>
          <div class="metric"><div class="small">Quantiles</div><strong>{{ result.config.quantiles }}</strong></div>
          <div class="metric"><div class="small">Composite</div><strong>{{ result.composite_factor or 'disabled' }}</strong></div>
        </div>
      </section>
      <section class="card">
        <h2>因子结果</h2>
        <table>
          <thead>
            <tr>
              <th>Factor</th>
              <th>IC</th>
              <th>Rank IC</th>
              <th>IR</th>
              <th>Rank IR</th>
              <th>Observations</th>
              <th>Positive IC Rate</th>
            </tr>
          </thead>
          <tbody>
            {% for item in result.results %}
            <tr>
              <td>{{ item.factor }}</td>
              <td>{{ item.ic }}</td>
              <td>{{ item.rank_ic }}</td>
              <td>{{ item.ir }}</td>
              <td>{{ item.rank_ir }}</td>
              <td>{{ item.observations }}</td>
              <td>{{ item.positive_ic_rate }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </section>
      <section class="card">
        <h2>分层收益</h2>
        {% for item in result.quantile_returns %}
        <h3>{{ item.factor }} / top-bottom spread={{ item.top_bottom_spread }}</h3>
        <table>
          <thead>
            <tr><th>Bucket</th><th>Mean Forward Return</th></tr>
          </thead>
          <tbody>
            {% for bucket in item.buckets %}
            <tr>
              <td>{{ bucket.bucket }}</td>
              <td>{{ bucket.mean_forward_return }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
        {% endfor %}
      </section>
    </div>
  </body>
</html>
