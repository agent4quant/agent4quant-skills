<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ result.symbol }} 风险分析</title>
    <style>
      body { margin: 0; padding: 32px; font-family: "Helvetica Neue", "PingFang SC", sans-serif; background: #f6f7fb; color: #0f172a; }
      .wrap { max-width: 1080px; margin: 0 auto; }
      .card { background: #ffffff; border-radius: 24px; padding: 24px; margin-bottom: 18px; box-shadow: 0 18px 42px rgba(15,23,42,0.08); }
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; }
      .metric { padding: 16px; border-radius: 16px; background: linear-gradient(135deg, #eff6ff, #f8fafc); }
      table { width: 100%; border-collapse: collapse; }
      th, td { text-align: left; padding: 10px 12px; border-bottom: 1px solid #e2e8f0; }
      .small { color: #64748b; font-size: 14px; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <section class="card">
        <p class="small">Agent4Quant / Quant Risk Report</p>
        <h1>{{ result.symbol }} 风险分析</h1>
        <p class="small">Mode: {{ result.mode }} / Source: {{ result.source }} / Interval: {{ result.period.interval }}</p>
        {% if result.strategy %}<p class="small">Strategy: {{ result.strategy }}</p>{% endif %}
        <p>{{ result.metadata.disclaimer }}</p>
      </section>
      <section class="card">
        <h2>核心指标</h2>
        <div class="grid">
          {% for key, value in result.metrics.items() %}
          <div class="metric">
            <div class="small">{{ key }}</div>
            <strong>{{ value }}</strong>
          </div>
          {% endfor %}
        </div>
      </section>
      <section class="card">
        <h2>Rolling VaR</h2>
        <p class="small">Window: {{ result.analysis_config.rolling_window }} / Points: {{ result.rolling_var|length }}</p>
        <table>
          <thead>
            <tr><th>index</th><th>label</th><th>rolling_var</th></tr>
          </thead>
          <tbody>
            {% for item in result.rolling_var[:12] %}
            <tr><td>{{ item.index }}</td><td>{{ item.label }}</td><td>{{ item.rolling_var }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </section>
      <section class="card">
        <h2>Rolling Volatility</h2>
        <p class="small">Window: {{ result.analysis_config.rolling_window }} / Points: {{ result.rolling_volatility|length }}</p>
        <table>
          <thead>
            <tr><th>index</th><th>label</th><th>rolling_annualized_volatility</th></tr>
          </thead>
          <tbody>
            {% for item in result.rolling_volatility[:12] %}
            <tr><td>{{ item.index }}</td><td>{{ item.label }}</td><td>{{ item.rolling_annualized_volatility }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </section>
      <section class="card">
        <h2>Drawdown Series</h2>
        <p class="small">Points: {{ result.drawdown_series|length }}</p>
        <table>
          <thead>
            <tr><th>index</th><th>label</th><th>drawdown</th></tr>
          </thead>
          <tbody>
            {% for item in result.drawdown_series[:12] %}
            <tr><td>{{ item.index }}</td><td>{{ item.label }}</td><td>{{ item.drawdown }}</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </section>
      <section class="card">
        <h2>Stress Test</h2>
        <table>
          <thead>
            <tr><th>shock</th><th>stressed_mean_return</th><th>stressed_worst_return</th></tr>
          </thead>
          <tbody>
            {% for item in result.stress_results %}
            <tr>
              <td>{{ item.shock }}</td>
              <td>{{ item.stressed_mean_return }}</td>
              <td>{{ item.stressed_worst_return }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </section>
      <section class="card">
        <h2>说明</h2>
        <table>
          <tbody>
            <tr><th>symbol</th><td>{{ result.symbol }}</td></tr>
            <tr><th>benchmark_symbol</th><td>{{ result.benchmark_symbol }}</td></tr>
            <tr><th>mode</th><td>{{ result.mode }}</td></tr>
            <tr><th>source</th><td>{{ result.source }}</td></tr>
            <tr><th>interval</th><td>{{ result.period.interval }}</td></tr>
          </tbody>
        </table>
      </section>
    </div>
  </body>
</html>
